# Supabase Postgres (Directus DB backend)
# Get from Supabase Dashboard -> Project Settings -> Database -> Connection string -> Session pooler
SUPABASE_DB_HOST=aws-0-xx-xxxxx-x.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_DATABASE=postgres
SUPABASE_DB_USER=postgres.xxxxxxxxxxxxxxxxxxxx
SUPABASE_DB_PASSWORD=change-me

# --- Directus ---
DIRECTUS_KEY=generate-a-uuid
DIRECTUS_SECRET=generate-a-random-hex-string
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=change-me
DIRECTUS_CORS_ORIGIN=http://localhost:3000
DIRECTUS_PUBLIC_URL=http://localhost:3000/panel/

# --- Nuxt (public, dipakai browser) ---
NUXT_PUBLIC_DIRECTUS_URL=http://localhost:8055

# --- MinIO (S3 self-hosted) ---
MINIO_ROOT_USER=change-me
MINIO_ROOT_PASSWORD=change-me
STORAGE_S3_BUCKET=sejarah-persib
